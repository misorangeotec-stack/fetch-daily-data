# Copy this file to .env and fill in real values. Never commit .env.

# --- Google APIs (Sheets, Drive, Slides) ---
# Path to OAuth client secrets and cached token (gitignored)
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# --- Tally Prime (if used via local ODBC/HTTP bridge) ---
TALLY_HOST=http://localhost:9000

# --- Add other API keys below as workflows need them ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# FIRECRAWL_API_KEY=
